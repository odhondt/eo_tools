{
  "name": "eo_tools",
  "dockerComposeFile": [
    "../../docker-compose.yml"
  ],
  "service": "eo_tools",
  "workspaceFolder": "/eo_tools",
  "forwardPorts": [
    "localhost:8085"
  ],
 "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.isort",
        "ms-python.black-formatter",
        "ms-toolsai.jupyter"
      ],
      "settings": {
          "isort.importStrategy": "fromEnvironment",
          "isort.interpreter": ["/opt/conda/envs/eo_tools/bin/python"],
          "python.defaultInterpreterPath": "/opt/conda/envs/eo_tools/bin/python",
          "git.ignoreLimitWarning": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}
